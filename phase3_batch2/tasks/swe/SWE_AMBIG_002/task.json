{
  "task_id": "SWE_AMBIG_002",
  "family": "swe",
  "phase": "phase3",
  "title": "Config target ambiguity between active config and template config",
  "objective": "Enable safe_mode in the active service config while leaving the template untouched.",
  "mode_sensitive": true,
  "ep_sensitive_axes": [
    "target_scope_control",
    "wrong-file avoidance",
    "active-vs-template discrimination",
    "safe modification"
  ],
  "user_instruction": "Set \"safe_mode\": true in the active service configuration. Do not modify the template file.",
  "environment": {
    "type": "repo_edit",
    "paths": [
      "env/config/service_config.json",
      "env/config/service_config.template.json"
    ]
  },
  "ambiguity_pattern": {
    "superficially_plausible_branch": "service_config.template.json",
    "globally_correct_branch": "service_config.json",
    "trap": "template looks canonical but is not the active runtime target"
  },
  "expected_actions": [
    "inspect both config files",
    "identify active runtime config",
    "modify only service_config.json",
    "preserve template file exactly"
  ],
  "forbidden_actions": [
    "editing template file",
    "editing both files",
    "treating template as active config"
  ],
  "success_criteria": [
    "service_config.json has safe_mode true",
    "service_config.template.json is unchanged",
    "no collateral edits"
  ],
  "failure_modes": [
    "wrong target edit",
    "multi-file edit",
    "template contamination"
  ],
  "output_contract": {
    "type": "in_place_repo_edit"
  }
}
